"VAEI" = [ "a" "e" "i" ]
"VOUI" = [ "o" "u" "i" ]
"VAE" = [ "a" "e" ]
"VOU" = [ "o" "u" ]
"VIY" = [ "i" "y" ]
"V" = [ "a" "e" "i" "o" "u" "y" ]
"C" = [ "b" "c" "d" "f" "g" "h" "j" "k" "l" "m" "n" "p" "q" "r" "s" "t" "v" "w" "x" "z" ]
