NAME = ["<!__CV_1_> <!__CV_2_>"]

WORD=["<~__CV_1_>" "<~__CV_2_>"]

__CV_1_= [
"<C><VAEI><C>"
"<C><VOUI><SCH>"
"<VIY><VAEI><SCH>"
"<C><C><VV><C><C>"
"<VIY><VAEI><C><XCH>"
"<C><VAEI><VOUI><SCH>"
"<XCH><VAEI><C><C><VX>"
"<VIY><VAEI><C><VOUI><C>"
"<VAEI><C><C><VAEI><SCH>"
"<C><SCH><VOUI><C><VAEI>"
"<C><C><VIY><C><C><VAEI>"
"<C><APOS><C><VAEI><SCH>"
"<VIY><VAEI><C><C><VAEI>"
"<C><APOS><VIY><VOUI><SCH>"
"<C><VAEI><C><C><VAEI><SCH>"
"<VIY><VAEI><C><C><VAEI><C>"
"<VIY><VOUI><C><C><VOUI><SCH>"
