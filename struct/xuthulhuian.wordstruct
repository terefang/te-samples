"<C><APOS><C><VIY><APOS><C><C>"
"<C><VAEI><C><VOUI><C><C><VAEI>"
]
__CV_2_= [
"<C><VIY><SCH><VAEI><C><VAEI><C>"
"<VIY><C><APOS><C><VAEI><VAEI><SCH>"
"<C><C><VIY><C><VAEI><C><C><VOUI><C>"
"<C><VAEI><DASH><VAEI><C><C><C><VOUI>"
"<C><APOS><VIY><VAEI><DASH><C><VAEI><C>"
"<C><C><VAEI><C><C><DASH><C><SCH><VOUI><C>"
"<VAEI><C><C><VOUI><DASH><C><VAEI><C><VAEI><C>"
"<VIY><VAEI><C><VAEI><C><DASH><C><VAEI><C><C><VAEI>"
"<C><C><C><VAEI><C><DASH><VAEI><XCH><APOS><VIY><VAEI>"
]

# - rules 
"DASH" = [ "-" ]
"APOS" = [ "'" ]
"SCH" = [ "dh" "gh" "lh" "rh" "th" ]
"XCH" = [ "ch" "kh" "ph" "sh" ]
"CH" = [ "ch" "dh" "gh" "kh" "lh" "ph" "rh" "sh" "th" ]
